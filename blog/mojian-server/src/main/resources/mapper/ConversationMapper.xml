<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mojian.mapper.ConversationMapper">

    <resultMap id="ConversationVoMap" type="com.mojian.vo.ai.ConversationVo">
        <id property="id" column="id"/>
        <result property="agentId" column="agent_id"/>
        <result property="agentName" column="agent_name"/>
        <result property="agentAvatar" column="agent_avatar"/>
        <result property="title" column="title"/>
        <result property="summary" column="summary"/>
        <result property="totalTokensUsed" column="total_tokens_used"/>
        <result property="messageCount" column="message_count"/>
        <result property="status" column="status"/>
        <result property="isPinned" column="is_pinned"/>
        <result property="lastActiveAt" column="last_active_at"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <select id="selectConversationVoPage" resultMap="ConversationVoMap">
        select
            c.id,
            c.agent_id,
            a.name as agent_name,
            a.avatar_url as agent_avatar,
            c.title,
            c.summary,
            c.total_tokens_used,
            c.message_count,
            c.status,
            c.is_pinned,
            c.last_active_at,
            c.create_time
        from ai_conversations c
        left join ai_agents a on c.agent_id = a.id
        <where>
            c.deleted_at is null
            <if test="agentId != null">
                and c.agent_id = #{agentId}
            </if>
            <if test="userId != null">
                and c.user_id = #{userId}
            </if>
        </where>
        order by c.is_pinned desc, c.last_active_at desc
    </select>

    <select id="selectConversationVoById" resultMap="ConversationVoMap">
        select
            c.id,
            c.agent_id,
            a.name as agent_name,
            a.avatar_url as agent_avatar,
            c.title,
            c.summary,
            c.total_tokens_used,
            c.message_count,
            c.status,
            c.is_pinned,
            c.last_active_at,
            c.create_time
        from ai_conversations c
        left join ai_agents a on c.agent_id = a.id
        where c.id = #{id} and c.deleted_at is null
    </select>

</mapper>
